<idea-plugin>
    <id>de.soptim.opencgmes.cimcheck</id>
    <name>CIMcheck</name>
    <vendor email="info@soptim.de" url="https://www.soptim.de/">SOPTIM AG</vendor>

    <description><![CDATA[
        Real-time SPARQL and SHACL validation against CIM/CGMES schema profiles,
        powered by the CIMcheck language server.<br/><br/>

        Write a SPARQL query or SHACL shape and get immediate feedback:
        unknown classes and properties are underlined, syntax errors are highlighted,
        and semantic issues like domain/range mismatches are flagged as you type —
        all resolved against your actual RDFS profile files.<br/><br/>

        <b>Features:</b>
        <ul>
            <li>Real-time diagnostics (unknown terms, type mismatches, cardinality errors)</li>
            <li>Hover documentation — full IRI and source profile for any CIM term</li>
            <li>Auto-completion after <code>cim:</code> and other prefixes</li>
            <li>Go-to-definition — jump to the term's declaration in the profile file</li>
            <li>Workspace symbol search — find any schema term by name</li>
        </ul>

        <b>Requires Java 21+</b> to launch the language server, and the
        <a href="https://plugins.jetbrains.com/plugin/23257-lsp4ij">LSP4IJ</a> plugin.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- ── File types ────────────────────────────────────────────────── -->
        <!--
            Do NOT add language="…" here: IntelliJ resolves that attribute before loading
            the class, and the lookup can silently fail.  The Language is already carried
            by the LanguageFileType constructor and is picked up correctly at class load time.
        -->
        <fileType name="SPARQL"
                  implementationClass="de.soptim.opencgmes.cimcheck.intellij.SparqlFileType"
                  extensions="rq;sparql"
                  fieldName="INSTANCE"/>

        <!--
            Deliberate decision: this claims the generic ".ttl" extension, not just ".shacl".
            ENTSO-E (and most tooling) ship SHACL shapes as plain ".ttl", and IntelliJ Community
            has no built-in Turtle file type, so claiming ".ttl" is what makes CIMcheck useful out
            of the box. Implications, accepted on purpose:
              • If another installed plugin also registers ".ttl", IntelliJ resolves the conflict by
                file-type precedence (last registration wins) — CIMcheck does not force itself.
              • A non-SHACL ".ttl" data file simply produces no diagnostics (no sh:* terms to check),
                so the cost of the broad claim is benign.
            Narrow this to extensions="shacl" only if Turtle support should be left to another plugin.
        -->
        <fileType name="SHACL"
                  implementationClass="de.soptim.opencgmes.cimcheck.intellij.ShaclFileType"
                  extensions="ttl;shacl"
                  fieldName="INSTANCE"/>

        <!-- ── Syntax highlighting ───────────────────────────────────────── -->
        <!--
            Registered by file type NAME rather than Language ID so there is no
            dependency on a Language singleton being initialised first.
        -->
        <editorHighlighterProvider
            fileType="SPARQL"
            implementationClass="de.soptim.opencgmes.cimcheck.intellij.CimcheckEditorHighlighterProvider"/>

        <editorHighlighterProvider
            fileType="SHACL"
            implementationClass="de.soptim.opencgmes.cimcheck.intellij.CimcheckEditorHighlighterProvider"/>

        <!-- ── Application-level settings service ────────────────────────── -->
        <applicationService
            serviceImplementation="de.soptim.opencgmes.cimcheck.intellij.settings.CimcheckSettings"/>

        <!-- ── Settings page under Settings > Tools > CIMcheck ───────────── -->
        <applicationConfigurable
            parentId="tools"
            displayName="CIMcheck"
            id="de.soptim.opencgmes.cimcheck.settings"
            instance="de.soptim.opencgmes.cimcheck.intellij.settings.CimcheckSettingsConfigurable"/>

    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">

        <!-- ── Language server registration ─────────────────────────────── -->
        <server id="cimcheck-lsp"
                name="CIMcheck"
                factoryClass="de.soptim.opencgmes.cimcheck.intellij.CimcheckServerConnectionProvider"
                lastDocumentDisconnectedTimeout="5000"/>

        <!-- ── File-type → server mappings ─────────────────────────────────
             fileTypeMapping activates by FileType.getName() (the string returned by our
             SparqlFileType / ShaclFileType), which is available as soon as the class is
             loaded — more reliable than languageMapping (which requires Language lookup).
        -->
        <fileTypeMapping fileType="SPARQL"
                         serverId="cimcheck-lsp"
                         languageId="sparql"/>

        <fileTypeMapping fileType="SHACL"
                         serverId="cimcheck-lsp"
                         languageId="shacl"/>

    </extensions>
</idea-plugin>
