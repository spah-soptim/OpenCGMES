@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix ex:   <http://example.org/shapes#> .
@prefix cim:  <http://iec.ch/TC57/CIM100#> .

ex:
    sh:declare [ sh:prefix "cim" ; sh:namespace "http://iec.ch/TC57/CIM100#"^^xsd:anyURI ] .

# Cross-profile shape: pulls one term from EQ and one from TP.
ex:LineHostedByVoltageLevel
    a sh:NodeShape ;
    sh:targetClass cim:ACLineSegment ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:prefixes ex: ;
        sh:select """
            SELECT $this WHERE {
                $this cim:ACLineSegment.r ?r .
                $this cim:Equipment.EquipmentContainer/cim:VoltageLevel.nominalVoltage ?nv .
            }
        """ ;
    ] .
